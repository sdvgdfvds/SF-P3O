{
  "env": "Hopper-v4",
  "algo": "P3O-static",
  "seed": 7,
  "hp": {
    "lr": 0.0003,
    "buffer_size": 8192,
    "batch_size": 256,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "train_steps": 1500000,
    "epochs_per_update": 10,
    "clip_range": 0.2,
    "clip_grad_norm": 0.5,
    "hidden_size": 256,
    "activation": "<class 'torch.nn.modules.activation.Tanh'>",
    "spectral_interval": 10000,
    "tau_p": 0.05,
    "sigma_perturb": 0.02,
    "fisher_protect": 0.7,
    "stable_lr_ratio": 0.5,
    "perturb_cooldown": 50000,
    "ema_alpha": 0.005,
    "redo_tau": 0.1,
    "sp_shrink": 0.99,
    "sp_noise": 0.01,
    "sp_interval": 50000,
    "l2_init_coeff": 0.0001,
    "reset_rate": 0.01,
    "reset_frequency": 50000,
    "alpha_dkl": 0.4,
    "alpha_start": 0.6,
    "alpha_end": 0.2,
    "alpha_lambda": 4.0,
    "distill_loss_bound": 0.01,
    "distill_max_steps": 80,
    "reversal_step": 1000000
  },
  "settings": {
    "dual_pathway": false,
    "spectral_trigger": false,
    "fisher_perturb": false,
    "legacy_sbp": true,
    "alpha_mode": "dynamic"
  },
  "experiment": "plasticity_probe"
}