{
  "env": "Walker2d-v4",
  "algo": "P3O-static",
  "seed": 3,
  "hp": {
    "lr": 0.0003,
    "buffer_size": 8192,
    "batch_size": 256,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "train_steps": 500000,
    "epochs_per_update": 10,
    "clip_range": 0.2,
    "clip_grad_norm": 0.5,
    "hidden_size": 256,
    "activation": "<class 'torch.nn.modules.activation.Tanh'>",
    "spectral_interval": 10000,
    "tau_p": 0.15,
    "sigma_perturb": 0.02,
    "fisher_protect": 0.7,
    "stable_lr_ratio": 0.5,
    "reset_rate": 0.01,
    "reset_frequency": 50000,
    "alpha_dkl": 0.4,
    "alpha_start": 0.6,
    "alpha_end": 0.2,
    "alpha_lambda": 4.0,
    "distill_loss_bound": 0.01,
    "distill_max_steps": 80
  },
  "settings": {
    "dual_pathway": false,
    "spectral_trigger": false,
    "fisher_perturb": false,
    "legacy_sbp": true,
    "alpha_mode": "dynamic"
  }
}